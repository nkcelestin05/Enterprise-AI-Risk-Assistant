generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/enterprise_ai_risk_assistant/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  queries       Query[]
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Query {
  id              String          @id @default(cuid())
  userId          String
  queryText       String
  sanitizedQuery  String?
  routeType       String
  status          String          @default("completed")
  latencyMs       Float?
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  riskAssessment  RiskAssessment?
  ragResult       RagResult?
}

model RiskAssessment {
  id                String   @id @default(cuid())
  queryId           String   @unique
  creditScore       Int?
  debtToIncome      Float?
  annualIncome      Int?
  loanAmount        Int?
  yearsAtJob        Int?
  riskProbability   Float
  riskLevel         String
  recommendation    String
  modelVersion      String?
  confidence        Float?
  createdAt         DateTime @default(now())
  query             Query    @relation(fields: [queryId], references: [id], onDelete: Cascade)
}

model RagResult {
  id              String   @id @default(cuid())
  queryId         String   @unique
  retrievedChunks String
  answer          String
  similarityScores String?
  retrievalMethod  String?
  createdAt       DateTime @default(now())
  query           Query    @relation(fields: [queryId], references: [id], onDelete: Cascade)
}

model SecurityLog {
  id          String   @id @default(cuid())
  eventType   String
  severity    String
  details     String
  sourceIp    String?
  userId      String?
  createdAt   DateTime @default(now())
}

model PolicyDocument {
  id        String   @id @default(cuid())
  title     String
  content   String
  section   String?
  createdAt DateTime @default(now())
}

model SystemMetric {
  id          String   @id @default(cuid())
  metricName  String
  metricValue Float
  metadata    String?
  createdAt   DateTime @default(now())
}

model ModelPerformanceLog {
  id               String   @id @default(cuid())
  modelVersion     String
  accuracy         Float?
  precisionVal     Float?
  recallVal        Float?
  f1Score          Float?
  aucRoc           Float?
  totalSamples     Int      @default(0)
  trainingTimeMs   Float?
  featureImportance String?
  metadata         String?
  createdAt        DateTime @default(now())
}
